<div>
    <p>
        Título: <b>@Pelicula.Titulo</b>
        @if (DateTime.Today.Subtract(Pelicula.FechaLanzamiento).TotalDays <= 14)
        {
            <span style="color: red"> - (¡Recién lanzada!)</span>
        }
    </p>
    <p>Fecha de lanzamiento: <b>@Pelicula.FechaLanzamiento.ToString("dd MMM yyyy")</b></p>
    @if(MostrarBotones)
    {
        <div>
            <button @onclick="Eliminar">Borrar</button>
        </div>
    }
</div>

@code {
    [Parameter]
    [EditorRequired]
    public Pelicula Pelicula { get; set; } = null!;
    [Parameter]
    public bool MostrarBotones { get; set; } = false;

    private void Eliminar() => Console.WriteLine($"Eliminando la película {Pelicula.Titulo}");
}
