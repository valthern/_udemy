@using BlogCoreSolution.Models
@model IEnumerable<ApplicationUser>
@{
    ViewBag.Title = "Lista de Usuarios";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-8">
            <h2 class="text-primary">Lista de Usuarios</h2>
        </div>

        <div class="col-4 text-right">
            <a asp-area="Identity" class="btn btn-info">
                <i class="fa-solid plus"></i> Crear Nuevo Usuario
            </a>
        </div>
    </div>

    <br />
    <br />

    @if (Model.Count() > 0)
    {
        <table id="tblUsuarios" class="table table-striped table-bordered" style="width: 100%">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Id)</td>
                        <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                        <td>@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>
                            @if(item.LockoutEnd is null || item.LockoutEnd < DateTime.Now)
                            {
                                <a class="btn btn-success text-white" asp-action="Bloquear" style="width: 150px;" asp-route-id="@item.Id">
                                    <i class="lock"></i> Bloquear
                                </a>
                            }
                            else
                            {
                                <a class="btn btn-danger text-white" asp-action="Desbloquear" style="width: 150px;" asp-route-id="@item.Id">
                                    <i class="unlock"></i> Desbloquear
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            No hay usuarios registrados.
        </div>
    }
</div>
