@model ConfirmarAccesoExternoViewModel
<h2 class="mb-4 text-center">¡Correo confirmado!</h2>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-1">
                <div class="card-body p-4">

                    <p>Hemos recibido tu correo desde Facebook:</p>
                    <strong>@Model.Email</strong>

                    <p>Para finalizar el proceso, confirma que deseas crear tu cuenta con este correo.</p>

                    <form asp-action="ConfirmarAccesoExterno" method="post">
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="ReturnUrl" />

                        <button type="submit" class="btn btn-success w-100">Confirmar Cuenta</button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
